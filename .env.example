# Copie este arquivo para .env e preencha os valores

# Chave da API Anthropic (Claude)
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL do Webhook do n8n (gerada pelo Webhook node)
# Exemplo local: http://localhost:5678/webhook/executar-analise
# Exemplo ngrok: https://xxxx.ngrok.io/webhook/executar-analise
# Deixe vazio para rodar o pipeline localmente sem n8n
WEBHOOK_URL=https://mateuscruz.app.n8n.cloud/webhook/executar-analise
